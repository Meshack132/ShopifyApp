@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
    <div style="text-align:center; max-width:440px;">
        <div style="font-size:3.5rem; margin-bottom:16px; opacity:0.25; color:#1a1a2e;">
            <i class="fas fa-triangle-exclamation"></i>
        </div>
        <h2 style="font-size:1.3rem; font-weight:700; color:#1a1a2e; margin-bottom:8px;">
            Something went wrong
        </h2>
        <p style="color:#888; font-size:0.875rem; line-height:1.6; margin-bottom:24px;">
            An unexpected error occurred while processing your request.
        </p>

        @if (Model.ShowRequestId)
        {
            <div style="background:#f8f9fa; border:1px solid #e8eaed; border-radius:8px; padding:12px 16px; margin-bottom:24px; text-align:left;">
                <div style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:#888; margin-bottom:4px;">Request ID</div>
                <code style="font-size:0.8rem; color:#333;">@Model.RequestId</code>
            </div>
        }

        <div style="display:flex; gap:10px; justify-content:center;">
            <a href="/" class="btn-g"><i class="fas fa-house"></i> Go Home</a>
            <a href="javascript:history.back()" class="btn-ghost">
                <i class="fas fa-arrow-left"></i> Go Back
            </a>
        </div>
    </div>
</div>
